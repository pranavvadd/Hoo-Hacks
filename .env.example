# Copy to `Ai Integrations/.env` (scripts load that path) or use repo-root `.env`.
# Never commit a real `.env` file.

# --- Provider routing ---
LEARNLENS_IMAGE_PROVIDER=
LEARNLENS_VIDEO_PROVIDER=
LEARNLENS_MUSIC_PROVIDER=

# --- Google / Vertex (Imagen, Lyria, genai client) ---
# Auth: `gcloud auth application-default login` locally, or set GOOGLE_APPLICATION_CREDENTIALS.
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=
GOOGLE_GENAI_USE_VERTEXAI=
# VERTEX_IMAGEN_MODEL=
# VERTEX_LYRIA_MODEL=

# --- ElevenLabs (TTS, Music). Alias: ELEVEN_API_KEY ---
ELEVENLABS_API_KEY=
# ELEVENLABS_TTS_VOICE_ID=
# ELEVENLABS_TTS_MODEL=
# ELEVENLABS_MUSIC_MODEL=
# ELEVENLABS_MUSIC_LENGTH_MS=
# ELEVENLABS_MUSIC_OUTPUT_FORMAT=

# --- Runway Gen-4 video (secret or key) ---
RUNWAYML_API_SECRET=
# RUNWAY_API_KEY=
# RUNWAY_TEXT_TO_VIDEO_MODEL=
# RUNWAY_IMAGE_TO_VIDEO_MODEL=

# --- Ideogram (when LEARNLENS_IMAGE_PROVIDER=ideogram) ---
IDEOGRAM_API_KEY=

# --- Google Cloud Text-to-Speech (narration in music pipeline) ---
# GOOGLE_TTS_VOICE=
# Redis (use Upstash for free hosted Redis, or redis://localhost:6379 locally)
REDIS_URL=redis://localhost:6379

# AWS S3
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=us-east-2
S3_BUCKET_NAME=hoohacks-learnlens-bucket
